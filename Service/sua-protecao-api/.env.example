# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ─── JWT — Access token (obrigatório) ─────────────────────────────────────────
JWT_SECRET=troque-por-um-secret-longo-e-aleatorio-para-access-token
JWT_EXPIRES_IN=15m

# ─── Reset de senha — Secret SEPARADO do JWT (obrigatório) ───────────────────
# Use: openssl rand -hex 64
PASSWORD_RESET_SECRET=troque-por-um-secret-longo-e-aleatorio-para-reset

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Origem(ns) permitida(s) pelo CORS — geralmente a URL do frontend
CORS_ORIGIN=http://localhost:3000

# ─── SMTP (e-mail) ────────────────────────────────────────────────────────────
# Dev: use MailHog (localhost:1025) ou Mailtrap — sem autenticação necessária
# Prod: configure seu provedor (SendGrid, AWS SES, Brevo, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sua Proteção" <noreply@suaprotecao.com.br>

# ─── Admin padrão (seed) ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@suaprotecao.com.br
ADMIN_PASSWORD=SenhaForte@2024!
